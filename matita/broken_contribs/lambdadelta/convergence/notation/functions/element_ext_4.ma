(* NOTATION FOR CONVERGENCE *************************************************)

notation < "hvbox( 𝗲𝘅𝘁 break term 70 f ␣ term 71 u )"
  non associative with precedence 70
  for @{ 'ElementExt $A1 $A0 $f $u }.
